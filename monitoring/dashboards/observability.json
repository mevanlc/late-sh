{
  "id": null,
  "uid": "observability",
  "title": "Errors & Traces",
  "timezone": "browser",
  "version": 4,
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "errors",
    "observability"
  ],
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "query": "label_values(traces_span_metrics_calls_total, service_name)",
        "datasource": {
          "uid": "victoriametrics",
          "type": "victoriametrics-metrics-datasource"
        },
        "refresh": 2,
        "allValue": ".+",
        "includeAll": true,
        "multi": false,
        "current": {}
      },
      {
        "name": "trace_service",
        "label": "Trace Service",
        "type": "query",
        "query": "label_values(traces_span_metrics_calls_total, service_name)",
        "datasource": {
          "uid": "victoriametrics",
          "type": "victoriametrics-metrics-datasource"
        },
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Throughput (RPS)",
      "datasource": {
        "uid": "victoriametrics",
        "type": "victoriametrics-metrics-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_total{service_name=~\"$service\"}[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Error Rate (%)",
      "datasource": {
        "uid": "victoriametrics",
        "type": "victoriametrics-metrics-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_total{service_name=~\"$service\", status_code=\"STATUS_CODE_ERROR\"}[5m])) / sum by (service_name) (rate(traces_span_metrics_calls_total{service_name=~\"$service\"}[5m])) * 100",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "p99 Latency (ms)",
      "datasource": {
        "uid": "victoriametrics",
        "type": "victoriametrics-metrics-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le, service_name) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=~\"$service\"}[5m])))",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      }
    },
    {
      "type": "nodeGraph",
      "title": "Service Graph",
      "datasource": {
        "uid": "victoriatraces",
        "type": "jaeger"
      },
      "targets": [
        {
          "datasource": {
            "type": "jaeger",
            "uid": "victoriatraces"
          },
          "refId": "A",
          "queryType": "dependencyGraph",
          "limit": 20,
          "tableType": "traces",
          "metricsQueryType": "range",
          "serviceMapUseNativeHistograms": false
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "options": {
        "zoomMode": "cooperative",
        "layoutAlgorithm": "layered",
        "nodes": {},
        "edges": {}
      }
    },
    {
      "type": "bargauge",
      "title": "Top Slowest Routes (p99)",
      "description": "Slowest HTTP routes by p99 latency across all services",
      "datasource": {
        "uid": "victoriametrics",
        "type": "victoriametrics-metrics-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, histogram_quantile(0.99, sum by (le, service_name, http_request_method, http_route) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=~\"$service\", http_route!=\"\"}[$__rate_interval]))))",
          "legendFormat": "{{service_name}} {{http_request_method}} {{http_route}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      }
    },
    {
      "type": "logs",
      "title": "All Logs",
      "description": "All application logs with formatted output",
      "datasource": {
        "uid": "victorialogs",
        "type": "victoriametrics-logs-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service.name=~\"$service\"}",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 32
      }
    },
    {
      "type": "timeseries",
      "title": "SSH Sessions",
      "description": "Current active SSH sessions",
      "datasource": {
        "uid": "victoriametrics",
        "type": "victoriametrics-metrics-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "late_ssh_sessions_active",
          "legendFormat": "active sessions"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      }
    },
    {
      "type": "timeseries",
      "title": "SSH Traffic",
      "description": "SSH connections and successful browser pairings",
      "datasource": {
        "uid": "victoriametrics",
        "type": "victoriametrics-metrics-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(late_ssh_connections_total[$__rate_interval])",
          "legendFormat": "connections"
        },
        {
          "refId": "B",
          "expr": "rate(late_ssh_ws_pair_success_total[$__rate_interval])",
          "legendFormat": "ws pairs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 16,
            "lineWidth": 2,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      }
    },
    {
      "type": "timeseries",
      "title": "Interaction Rate",
      "description": "Chat sends, votes, and page views",
      "datasource": {
        "uid": "victoriametrics",
        "type": "victoriametrics-metrics-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(late_ssh_chat_messages_sent_total[$__rate_interval])",
          "legendFormat": "chat messages"
        },
        {
          "refId": "B",
          "expr": "sum(rate(late_ssh_votes_cast_total[$__rate_interval]))",
          "legendFormat": "votes"
        },
        {
          "refId": "C",
          "expr": "sum by (page) (rate(late_web_page_views_total[$__rate_interval]))",
          "legendFormat": "page {{page}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 16,
            "lineWidth": 2,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      }
    },
    {
      "type": "timeseries",
      "title": "Reliability Signals",
      "description": "Frame drops and late-web now-playing fetch results",
      "datasource": {
        "uid": "victoriametrics",
        "type": "victoriametrics-metrics-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(late_ssh_render_frame_drops_total[$__rate_interval])",
          "legendFormat": "frame drops"
        },
        {
          "refId": "B",
          "expr": "sum by (result) (rate(late_web_now_playing_fetch_total[$__rate_interval]))",
          "legendFormat": "now-playing {{result}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 16,
            "lineWidth": 2,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      }
    },
    {
      "type": "logs",
      "title": "Error Logs: late-web",
      "description": "Recent error logs for late-web",
      "datasource": {
        "uid": "victorialogs",
        "type": "victoriametrics-logs-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service.name=\"late-web\"} severity:ERROR",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 0,
        "y": 44
      }
    },
    {
      "type": "logs",
      "title": "Error Logs: late-ssh",
      "description": "Recent error logs for late-ssh",
      "datasource": {
        "uid": "victorialogs",
        "type": "victoriametrics-logs-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service.name=\"late-ssh\"} severity:ERROR",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 12,
        "y": 44
      }
    },
    {
      "type": "table",
      "title": "Recent Traces",
      "description": "Latest traces from VictoriaTraces. Click a Trace ID to open the full trace view.",
      "datasource": {
        "uid": "victoriatraces",
        "type": "jaeger"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "victoriatraces",
            "type": "jaeger"
          },
          "queryType": "search",
          "tableType": "table",
          "service": "$trace_service",
          "tags": "",
          "minDuration": "",
          "maxDuration": "",
          "limit": 50
        }
      ],
      "transformations": [
        {
          "id": "limit",
          "options": {
            "limitField": 50
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "durationMs": "Duration (ms)",
              "rootService": "Service",
              "rootSpanName": "Root Span",
              "traceID": "Trace ID"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        },
        "sortBy": [
          {
            "displayName": "Start time",
            "desc": true
          }
        ],
        "cellHeight": "sm"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 56
      }
    },
    {
      "type": "table",
      "title": "Recent Error Traces: late-web",
      "description": "Recent late-web traces with error spans from VictoriaTraces.",
      "datasource": {
        "uid": "victoriatraces",
        "type": "jaeger"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "victoriatraces",
            "type": "jaeger"
          },
          "queryType": "search",
          "tableType": "table",
          "service": "late-web",
          "tags": "error=true",
          "minDuration": "",
          "maxDuration": "",
