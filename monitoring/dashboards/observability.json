            "limitField": 25
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "durationMs": "Duration (ms)",
              "rootService": "Service",
              "rootSpanName": "Root Span",
              "traceID": "Trace ID"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "filterable": false
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        },
        "sortBy": [
          {
            "displayName": "Start time",
            "desc": true
          }
        ],
        "cellHeight": "sm"
      },
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 0,
        "y": 68
      }
    },
    {
      "type": "table",
      "title": "Recent Error Traces: late-ssh",
      "description": "Recent late-ssh traces with error spans from VictoriaTraces.",
      "datasource": {
        "uid": "victoriatraces",
        "type": "jaeger"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "victoriatraces",
            "type": "jaeger"
          },
          "queryType": "search",
          "tableType": "table",
          "service": "late-ssh",
          "tags": "error=true",
          "minDuration": "",
          "maxDuration": "",
          "limit": 25
        }
      ],
      "transformations": [
        {
          "id": "limit",
          "options": {
            "limitField": 25
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "durationMs": "Duration (ms)",
              "rootService": "Service",
